<UserControl x:Class="MaidensRecipe.Views.Harvest.Command"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="10,0,20,0">
            <TextBlock Text="◆ 接続する触手の選択" Foreground="#E040FB" FontWeight="Bold" Margin="0,0,0,5"/>

            <ToggleButton x:Name="BtnTentacleSelect" Width="220" Height="45" Background="#1E1E1E" BorderBrush="#E040FB" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="[第1段階] 繊毛型触手" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text=" ▲" Foreground="#E040FB" VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>
            </ToggleButton>

            <Popup IsOpen="{Binding IsChecked, ElementName=BtnTentacleSelect}" 
       PlacementTarget="{Binding ElementName=BtnTentacleSelect}" 
       Placement="Top" PopupAnimation="Slide" AllowsTransparency="True" StaysOpen="False">

                <Border Background="#151515" BorderBrush="#E040FB" BorderThickness="1" CornerRadius="3" Width="220" Margin="0,0,0,5" Padding="5">

                    <ItemsControl ItemsSource="{Binding DataContext.TentacleTechTree, RelativeSource={RelativeSource AncestorType=Window}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Name}" 
                            IsEnabled="{Binding IsUnlocked}" 
                            ToolTip="{Binding UnlockCondition}"
                            Height="30" BorderThickness="0" Margin="0,2">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="#4A148C"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter Property="Background" Value="#2A2A2A"/>
                                                    <Setter Property="Foreground" Value="#777777"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </Border>
            </Popup>
        </StackPanel>

        <WrapPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">

            <Button Width="200" Height="50" Margin="10" Background="#4E342E" BorderBrush="#E65100" BorderThickness="1" Click="BtnTestPhysical_Click">
                <StackPanel>
                    <TextBlock Text="[物理] 快楽を与える" Foreground="White" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center"/>
                    <TextBlock Text="選択部位に物理快楽を付与" Foreground="#FFB74D" FontSize="11" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Width="200" Height="50" Margin="10" Background="#311B92" BorderBrush="#8E24AA" BorderThickness="1" Click="BtnTestState_Click">
                <StackPanel>
                    <TextBlock Text="[精神] 屈辱を与える" Foreground="White" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center"/>
                    <TextBlock Text="尊厳防壁を削り倒錯快楽UP" Foreground="#BA68C8" FontSize="11" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

        </WrapPanel>
    </Grid>
</UserControl>