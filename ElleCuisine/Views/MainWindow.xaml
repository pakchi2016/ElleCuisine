<Window x:Class="MaidensRecipe.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tactical="clr-namespace:MaidensRecipe.Views.Tactical"
        xmlns:battle="clr-namespace:MaidensRecipe.Views.Battle"
        xmlns:harvest="clr-namespace:MaidensRecipe.Views.Harvest"
        Title="Maiden's Recipe" Height="800" Width="1280" Background="#1E1E1E">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
            <RowDefinition Height="180" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="400" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Background="#2D2D30" Margin="5,0,5,5">
            <TextBlock Text="【開発用フェーズ切替】" Foreground="Yellow" VerticalAlignment="Center" Margin="10,0"/>
            <Button Content="1. 待機フェーズ" Width="120" Margin="5" Click="BtnPhaseStandby_Click" Background="#444" Foreground="White"/>
            <Button Content="2. 捕獲フェーズ" Width="120" Margin="5" Click="BtnPhaseCapture_Click" Background="#444" Foreground="White"/>
            <Button Content="3. 搾取フェーズ" Width="120" Margin="5" Click="BtnPhaseExploit_Click" Background="#444" Foreground="White"/>

            <Button Content="★1. 敵襲来" Width="100" Margin="5" Click="BtnGenerateEnemy_Click" Background="#6B2F2F" Foreground="White" FontWeight="Bold"/>
            <Button Content="★2. 捕獲(搾取へ)" Width="100" Margin="5" Click="BtnCapture_Click" Background="#4A148C" Foreground="White" FontWeight="Bold"/>
            <Button Content="★3. 完了(収容へ)" Width="100" Margin="5" Click="BtnImprison_Click" Background="#1565C0" Foreground="White" FontWeight="Bold"/>
        </StackPanel>

        <Grid Grid.Row="1" Grid.Column="0">
            <tactical:Central x:Name="TacCentral" Visibility="Visible"/>
            <battle:Central x:Name="BatCentral" Visibility="Collapsed"/>
            <harvest:Central x:Name="HarCentral" Visibility="Collapsed" DataContext="{Binding HarvestTarget}"/>
        </Grid>

        <Grid Grid.Row="1" Grid.RowSpan="2" Grid.Column="1">
            <tactical:Side x:Name="TacSide" Visibility="Visible"/>
            <battle:Side x:Name="BatSide" Visibility="Collapsed"/>
            <harvest:Side x:Name="HarSide" Visibility="Collapsed" DataContext="{Binding HarvestTarget}"/>
        </Grid>

        <Grid Grid.Row="2" Grid.Column="0">
            <tactical:Command x:Name="TacCmd" Visibility="Visible"/>
            <battle:Command x:Name="BatCmd" Visibility="Collapsed"/>
            <harvest:Command x:Name="HarCmd" Visibility="Collapsed" DataContext="{Binding HarvestTarget}"/>
        </Grid>
    </Grid>
</Window>