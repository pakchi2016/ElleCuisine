<UserControl x:Class="MaidensRecipe.Views.Tactical.Central"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid>
        <Border x:Name="AreaMainLog" BorderBrush="#333333" BorderThickness="2" Background="#252526" CornerRadius="5" Margin="5" Visibility="Visible">
            <ScrollViewer Padding="15">
                <TextBlock Foreground="#CCCCCC" FontSize="16" TextWrapping="Wrap" LineHeight="24">
                    [待機] 罠の拡張を終え、新たな獲物が迷い込むのを静かに待ちます...<LineBreak/>
                    【Maiden's Recipe】の世界へようこそ。<LineBreak/>
                    [報告] 洗脳宿舎の設備効果により、エルザ(ジョーカー)のステータスが回復しました。
                </TextBlock>
            </ScrollViewer>
        </Border>

        <Border x:Name="AreaDashboard" BorderBrush="#FFC107" BorderThickness="2" Background="#2D2D30" CornerRadius="5" Margin="5" Visibility="Collapsed">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="【 収容所・ジョブ統合管理 】" Foreground="#FFC107" FontSize="22" FontWeight="Bold" Margin="0,0,0,15"/>
                <Button Content="✖ 閉じる" HorizontalAlignment="Right" Width="100" Height="30" Background="#444" Foreground="White"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="◆ 乙女の育成・配置パイプライン" Foreground="#AAA" FontSize="16" Margin="0,5,0,15"/>

                        <Border Background="#222" BorderBrush="#444" BorderThickness="1" Margin="0,5" Padding="15">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="[洗脳済] 魔法使い (Lv.12)" Foreground="#82B1FF" FontWeight="Bold" FontSize="16"/>
                                        <TextBlock Text="維持コスト: 80 EN / ターン" Foreground="#FF5252" FontSize="12" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="現在地: 洗脳宿舎" Foreground="#4CAF50"/>
                                        <TextBlock Text="回復量: +20 STA/T" Foreground="#CCC" FontSize="12"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="ジョブ: 娼婦稼業" Foreground="#E91E63"/>
                                        <TextBlock Text="稼ぎ: +150 EN/T" Foreground="#CCC" FontSize="12"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="ジョブ統合 (賢者へ)" Width="130" Height="30" Background="#444" Foreground="White" Margin="0,0,10,0" ToolTip="僧侶ジョブが必要です"/>
                                        <Button Content="ジョーカー昇格" Width="130" Height="30" Background="#6B2F2F" Foreground="White" ToolTip="能力値が閾値に達していません" IsEnabled="False"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="#222" BorderBrush="#444" BorderThickness="1" Margin="0,5" Padding="15">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="[監禁中] 僧侶 (Lv.8)" Foreground="#FFE082" FontWeight="Bold" FontSize="16"/>
                                        <TextBlock Text="維持コスト: 45 EN / ターン" Foreground="#FF5252" FontSize="12" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="現在地: 監禁部屋" Foreground="#999"/>
                                        <TextBlock Text="洗脳度: 20%" Foreground="#CCC" FontSize="12"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="ジョブ: 割り当て不可" Foreground="#777" VerticalAlignment="Center"/>

                                    <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="洗脳触手を実行" Width="130" Height="30" Background="#9C27B0" Foreground="White" Margin="0,0,10,0"/>
                                        <Button Content="廃人リリース" Width="130" Height="30" Background="#444" Foreground="#FF5252"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>