<UserControl x:Class="MaidensRecipe.Views.Battle.Side"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:comp="clr-namespace:MaidensRecipe.Components"
             Background="Transparent">

    <Border BorderBrush="#333333" BorderThickness="2" Background="#252526" CornerRadius="5" Margin="5">
        <StackPanel Margin="15">
            <TextBlock Text="【 侵略者パーティ (罠警戒中) 】" Foreground="#FF5252" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

            <ItemsControl ItemsSource="{Binding InvaderParty}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#2A2A2A" BorderBrush="#444" BorderThickness="1" CornerRadius="3" Margin="0,0,0,10" Padding="10">
                            <StackPanel>
                                <TextBlock FontWeight="Bold" FontSize="14" Margin="0,0,0,5">
                                    <Run Text="[" Foreground="#FFC107"/>
                                    <Run Text="{Binding maidenBase.JobClass}" Foreground="#FFC107"/>
                                    <Run Text="] " Foreground="#FFC107"/>
                                    <Run Text="{Binding maidenBase.Name}" Foreground="White"/>
                                </TextBlock>

                                <comp:StatusBar Title="HP" TextColor="#FF5252" BarColor="#FF5252" BarHeight="8"
                                                Value="{Binding maidenBase.CurrentHP}" Maximum="{Binding maidenBase.MaxHP}" Margin="0,2"/>

                                <Grid Margin="0,5,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <comp:StatusBar Grid.Column="0" Title="STA" TextColor="#4CAF50" BarColor="#4CAF50" Value="{Binding maidenBase.CurrentStamina}" Maximum="{Binding maidenBase.MaxStamina}" Margin="0,0,2,0"/>
                                    <comp:StatusBar Grid.Column="1" Title="MEN" TextColor="#2196F3" BarColor="#2196F3" Value="{Binding maidenBase.CurrentMental}" Maximum="{Binding maidenBase.MaxMental}" Margin="2,0"/>
                                    <comp:StatusBar Grid.Column="2" Title="DIG" TextColor="#FFC107" BarColor="#FFC107" Value="{Binding maidenBase.CurrentDignity}" Maximum="{Binding maidenBase.MaxDignity}" Margin="2,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </Border>
</UserControl>