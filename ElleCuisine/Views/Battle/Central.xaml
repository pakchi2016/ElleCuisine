<UserControl x:Class="MaidensRecipe.Views.Battle.Central"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Border BorderBrush="#333333" BorderThickness="2" Background="#252526" CornerRadius="5" Margin="5">
        <ScrollViewer Padding="15">
            <TextBlock Foreground="#CCCCCC" FontSize="16" TextWrapping="Wrap" LineHeight="24">
                [遭遇] 姫騎士のパーティが罠の深部に到達しました！ 戦闘を開始します。<LineBreak/>
                <Run Foreground="#FF6A80">姫騎士：「ここが噂の魔窟か……皆、油断するな！」</Run><LineBreak/>
                [警告] 対象は強力な防具（オブジェクト）を装備しています。<LineBreak/><LineBreak/>
                [戦闘] 前衛の盾を搔いくぐり、後衛の魔法使いから優先して精神力を削りますか？
            </TextBlock>
        </ScrollViewer>
    </Border>
</UserControl>